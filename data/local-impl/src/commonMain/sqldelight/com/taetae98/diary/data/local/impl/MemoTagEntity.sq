import com.taetae98.diary.data.local.impl.memo.tag.MemoTagStateEntity;

CREATE TABLE MemoTagEntity(
    memoId TEXT NOT NULL,
    tagId TEXT NOT NULL,
    state INTEGER AS MemoTagStateEntity NOT NULL,

    FOREIGN KEY (memoId) REFERENCES MemoEntity(id) ON DELETE CASCADE,
    FOREIGN KEY (tagId) REFERENCES TagEntity(id) ON DELETE CASCADE,
    PRIMARY KEY (memoId, tagId)
);

exists:
SELECT EXISTS (
    SELECT *
    FROM MemoTagEntity
    WHERE memoId = :memoId AND tagId = :tagId
);

delete:
UPDATE MemoTagEntity
SET state = 1
WHERE memoId = :memoId AND tagId = :tagId;

upsert:
INSERT INTO MemoTagEntity
VALUES ?
ON CONFLICT (memoId, tagId) DO
UPDATE SET
state = excluded.state
;

findByMemoId:
SELECT *
FROM MemoTagEntity
WHERE memoId = :memoId AND state = 0;